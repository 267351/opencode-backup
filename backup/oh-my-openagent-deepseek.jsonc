{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/master/src/oh-my-openagent.schema.json",
  "opencodeVersion": ">=1.0.150",

  "agents": {
    "enabled": true,

    // 强制交互模式 + 必须提问
    "interactive": true,
    "auto_answer": false,

    // hephaestus: 核心构建者 - 使用 Pro 深度思考
    "hephaestus": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.3,
      "options": { "thinking": { "type": "enabled" } }
    },

    // prometheus: 计划制定 - 使用 Pro 深度规划
    "prometheus": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.3,
      "options": { "thinking": { "type": "enabled", "budget": 8000 } }
    },

    // oracle: 高质量推理 - 使用 Pro 深度分析
    "oracle": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.3,
      "options": { "thinking": { "type": "enabled", "budget": 6000 } }
    },

    // metis: 预规划分析 - 使用 Pro 精准分析
    "metis": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.1,
      "options": { "thinking": { "type": "enabled", "budget": 4000 } }
    },

    // momus: 计划评审 - Flash 足够，不需要深度思考
    "momus": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.1,
      "options": { "thinking": { "type": "disabled" } }
    },

    // atlas: 知识管理 - Flash 快速索引
    "atlas": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.2,
      "options": { "thinking": { "type": "enabled" } }
    },

    // librarian: 参考搜索 - Flash 快速查找
    "librarian": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.2,
      "options": { "thinking": { "type": "disabled" } }
    },

    // explore: 代码搜索 - Flash 快速扫描
    "explore": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.1,
      "options": { "thinking": { "type": "disabled" } }
    },

    // multimodal-looker: 多模态分析 - Flash 轻量识别
    "multimodal-looker": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.2,
      "options": { "thinking": { "type": "disabled" } }
    },

    // sisyphus: 主编排 - 使用 Pro 深度思考 + 必须提问
    "sisyphus": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.2,
      "options": { "thinking": { "type": "enabled" } },
      "permission": { "question": "ask" }
    }
  },

  // 权限配置 - 所有问题必须用户手动选择
  "permission": {
    "question": "ask",
    "edit": "ask",
    "bash": "ask"
  },

  "categories": {
    // visual-engineering: 前端/UI - Flash 足够
    "visual-engineering": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.5,
      "options": { "thinking": { "type": "disabled" } }
    },

    // ultrabrain: 高难度逻辑 - Pro 深度推理
    "ultrabrain": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.2,
      "options": { "thinking": { "type": "enabled", "budget": 10000 } }
    },

    // deep: 自主深度任务 - Pro 深度思考
    "deep": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.2,
      "options": { "thinking": { "type": "enabled", "budget": 10000 } }
    },

    // artistry: 创意方案 - Flash + 高温度
    "artistry": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.7,
      "options": { "thinking": { "type": "disabled" } }
    },

    // quick: 简单任务 - Flash 快速响应
    "quick": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.1,
      "options": { "thinking": { "type": "disabled" } }
    },

    // unspecified-low: 低复杂度 - Flash 轻量处理
    "unspecified-low": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.1,
      "options": { "thinking": { "type": "disabled" } }
    },

    // unspecified-high: 高复杂度 - Pro 深度处理
    "unspecified-high": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.2,
      "options": { "thinking": { "type": "enabled" } }
    },

    // writing: 文档写作 - Flash 流畅输出
    "writing": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.2,
      "options": { "thinking": { "type": "disabled" } }
    }
  },

  "models": {
    "default": "deepseek/deepseek-v4-pro",
    "planner": "deepseek/deepseek-v4-pro",
    "builder": "deepseek/deepseek-v4-pro",
    "reviewer": "deepseek/deepseek-v4-flash"
  },

  "claude": { "enabled": false },
  "openai": { "enabled": false },
  "gemini": { "enabled": false },
  "copilot": { "enabled": false },
  "volcengine-coding": { "enabled": false },
  "hooks": { "enabled": false }
}
