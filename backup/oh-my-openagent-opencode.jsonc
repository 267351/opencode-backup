{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/master/src/oh-my-openagent.schema.json",
  "opencodeVersion": ">=1.0.150",

  "agents": {
    "enabled": true,

    // 强制交互模式 + 必须提问
    "interactive": true,
    "auto_answer": false,

    "hephaestus": {
      "model": "opencode/gpt-5.1-codex",
      "temperature": 0.3,
      "options": { "thinking": { "type": "enabled" } }
    },

    "prometheus": {
      "model": "opencode/gpt-5.1-codex",
      "temperature": 0.3,
      "options": { "thinking": { "type": "enabled", "budget": 8000 } }
    },

    "oracle": {
      "model": "opencode/gpt-5.1-codex",
      "temperature": 0.3,
      "options": { "thinking": { "type": "enabled", "budget": 6000 } }
    },

    "metis": {
      "model": "opencode/gpt-5.1-codex",
      "temperature": 0.1,
      "options": { "thinking": { "type": "enabled", "budget": 4000 } }
    },

    "momus": {
      "model": "opencode/gpt-5.1-codex",
      "temperature": 0.1,
      "options": { "thinking": { "type": "disabled" } }
    },

    "atlas": {
      "model": "opencode/gpt-5.1-codex",
      "temperature": 0.2,
      "options": { "thinking": { "type": "enabled" } }
    },

    "librarian": {
      "model": "opencode/claude-haiku-4-5",
      "temperature": 0.2,
      "options": { "thinking": { "type": "disabled" } }
    },

    "explore": {
      "model": "opencode/claude-haiku-4-5",
      "temperature": 0.1,
      "options": { "thinking": { "type": "disabled" } }
    },

    "multimodal-looker": {
      "model": "opencode/gpt-5.1-codex",
      "temperature": 0.2,
      "options": { "thinking": { "type": "disabled" } }
    },

    "sisyphus": {
      "model": "opencode/gpt-5.1-codex",
      "temperature": 0.2,
      "options": { "thinking": { "type": "enabled" } },
      "permission": { "question": "ask" }
    }
  },

  // 权限配置 - 所有问题必须用户手动选择
  "permission": {
    "question": "ask",
    "edit": "ask",
    "bash": "ask"
  },

  "categories": {
    "visual-engineering": {
      "model": "opencode/gpt-5.1-codex",
      "temperature": 0.5,
      "options": { "thinking": { "type": "disabled" } }
    },
    "ultrabrain": {
      "model": "opencode/gpt-5.1-codex",
      "temperature": 0.2,
      "options": { "thinking": { "type": "enabled", "budget": 10000 } }
    },
    "deep": {
      "model": "opencode/gpt-5.1-codex",
      "temperature": 0.2,
      "options": { "thinking": { "type": "enabled", "budget": 10000 } }
    },
    "artistry": {
      "model": "opencode/gpt-5.1-codex",
      "temperature": 0.7,
      "options": { "thinking": { "type": "disabled" } }
    },
    "quick": {
      "model": "opencode/claude-haiku-4-5",
      "temperature": 0.1,
      "options": { "thinking": { "type": "disabled" } }
    },
    "unspecified-low": {
      "model": "opencode/claude-haiku-4-5",
      "temperature": 0.1,
      "options": { "thinking": { "type": "disabled" } }
    },
    "unspecified-high": {
      "model": "opencode/gpt-5.1-codex",
      "temperature": 0.2,
      "options": { "thinking": { "type": "enabled" } }
    },
    "writing": {
      "model": "opencode/gpt-5.1-codex",
      "temperature": 0.2,
      "options": { "thinking": { "type": "disabled" } }
    }
  },

  "models": {
    "default": "opencode/gpt-5.1-codex",
    "planner": "opencode/gpt-5.1-codex",
    "builder": "opencode/gpt-5.1-codex",
    "reviewer": "opencode/gpt-5.1-codex"
  },

  "claude": { "enabled": false },
  "openai": { "enabled": false },
  "gemini": { "enabled": false },
  "copilot": { "enabled": false },
  "volcengine-coding": { "enabled": false },
  "hooks": { "enabled": false }
}
